{
 "$schema": "https://schema.tauri.app/v2/tauri.conf.json",
 "productName": "Front Line Whanau",
 "version": "0.4.0",
 "identifier": "nz.frontlinewhanau.app",
 "build": {
 "frontendDist": "https://front-line-whanau.vercel.app",
 "devUrl": "http://localhost:3000",
 "beforeDevCommand": "npm run dev"
 },
 "app": {
 "windows": [
 {
 "title": "Front Line Whanau",
 "width": 1200,
 "height": 800,
 "resizable": true,
 "fullscreen": false,
 "center": true
 }
 ],
 "security": {
 "csp": null
 }
 },
 "bundle": {
 "active": true,
 "targets": ["msi", "nsis", "deb", "appimage"],
 "createUpdaterArtifacts": false,
 "icon": [
 "icons/32x32.png",
 "icons/128x128.png",
 "icons/128x128@2x.png",
 "icons/icon.icns",
 "icons/icon.ico"
 ]
 }
}
