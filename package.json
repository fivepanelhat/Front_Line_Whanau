{
  "name": "front-line-whanau",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "description": "A sovereign, privacy-first digital platform supporting whānau of preterm twins navigating complex frontline services in Aotearoa New Zealand. Built with client-side encryption (Taonga Vault), Te Tiriti alignment, and LangGraph-powered AI orchestration.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu"
  },
  "keywords": [
    "preterm-twins",
    "neonatal-support",
    "privacy-first",
    "sovereign-ai",
    "langgraph",
    "nextjs",
    "supabase",
    "aotearoa",
    "te-tiriti",
    "maori-data-sovereignty"
  ],
  "author": "fivepanelhat",
  "license": "MIT",
