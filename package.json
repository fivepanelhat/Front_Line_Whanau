{
  "name": "front-line-whanau",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "description": "A sovereign, privacy-first digital platform supporting whānau of preterm twins navigating complex frontline services in Aotearoa New Zealand. Built with client-side encryption (Taonga Vault), Te Tiriti alignment, and LangGraph-powered AI orchestration.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "node .next/standalone/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval:agents": "node scripts/eval-agents.mjs",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e": "playwright test",
    "test:e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "validate": "npm run type-check && npm run lint && npm run test:coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu"
  },
  "keywords": [
    "preterm-twins",
    "neonatal-support",
    "privacy-first",
    "sovereign-ai",
    "langgraph",
    "nextjs",
    "supabase",
    "aotearoa",
    "te-tiriti",
    "maori-data-sovereignty"
  ],
  "author": "fivepanelhat",
  "license": "Apache-2.0",
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.6",
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.2.1",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@langchain/tavily": "^1.2.0",
    "@next/bundle-analyzer": "^16.2.9",
    "@sentry/nextjs": "^10.62.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tauri-apps/api": "^2.11.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.1",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13",
    "postcss": "^8.5.15",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
