{
  "name": "front-line-whanau",
  "private": true,
  "version": "0.2.0",
  "description": "Front Line Families Support Hub NZ — A sovereign, privacy-first digital platform supporting families of preterm twins in Aotearoa New Zealand.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose --coverage",
    "test:e2e": "playwright test",
    "docs:directory": "tsx scripts/generate-directory-doc.ts"
  },
  "keywords": [
    "neonatal",
    "preterm",
    "whanau",
    "support",
    "new-zealand",
    "privacy-first",
    "sovereign-ai"
  ],
  "author": "fivepanelhat",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.8.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "prisma": "^6.8.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
