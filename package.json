{
  "name": "front-line-whanau",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "description": "A sovereign, privacy-first digital platform supporting whānau of preterm twins navigating complex frontline services in Aotearoa New Zealand. Built with client-side encryption (Taonga Vault), Te Tiriti alignment, and LangGraph-powered AI orchestration.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:e2e": "playwright test",
    "docs:directory": "tsx scripts/generate-directory-doc.ts"
  },
  "keywords": [
    "preterm-twins",
    "neonatal-support",
    "privacy-first",
    "sovereign-ai",
    "langgraph",
    "nextjs",
    "supabase",
    "aotearoa",
    "te-tiriti",
    "maori-data-sovereignty"
  ],
  "author": "fivepanelhat",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.2.0",
    "@langchain/langgraph": "^1.4.4",
    "@langchain/openai": "^1.5.1",
    "@prisma/client": "^6.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/coverage-v8": "^3.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "prisma": "^6.8.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
