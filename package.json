    "@langchain/langgraph": "^1.4.4",
    "@prisma/client": "^6.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tauri-apps/api": "^2.11.1",
    "next": "^16.2.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
