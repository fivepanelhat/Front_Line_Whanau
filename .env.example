# ----------------------------------------------------------
# .env.example - Front Line Whanau
# ----------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored - never commit real credentials.
# ----------------------------------------------------------

# -- Supabase (REQUIRED) ------------------------------------
# Source: Supabase Dashboard -> Project Settings -> API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key - safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -- Supabase (Server-side REQUIRED) -----------------------
# ⚠️ NEVER expose this to the browser. Server/build use only.

# Service role key - bypasses RLS; guards are in createAdminClient()
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -- AI Provider -------------------------------------------
# Leave blank for stub mode - the app works without an API key.
# When set, the AI agent system will use this for LLM inference.
# Source: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# -- Aether Summit (Python Agent Backend) ------------------
# URL of the running FastAPI agent service (whanau-agents/).
# Local default: http://localhost:8000
# Production: set to your deployed service URL (e.g. Railway, Fly.io)
AETHER_SUMMIT_URL=http://localhost:8000

# -- Database (Prisma - OPTIONAL) --------------------------
# Source: Supabase Dashboard -> Project Settings -> Database
# Use the "Connection Pooling" URL for serverless environments
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
# Local dev alternative for LangGraph checkpointing:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/whanau_agents

# -- App Settings ------------------------------------------
# Canonical URL - used for OG tags, canonical links, redirects
# Production: https://frontlinewhanau.nz Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Display name (used in page titles and metadata)
NEXT_PUBLIC_APP_NAME="Front Line Whanau"

# App version - reported by /api/health endpoint
NEXT_PUBLIC_APP_VERSION=0.2.0
