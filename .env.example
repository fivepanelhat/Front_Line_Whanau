# ──────────────────────────────────────────────
# Front Line Whānau — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (Prisma) ─────────────────────────
DATABASE_URL=

# ── AI Provider (optional) ────────────────────
# Leave blank for stub mode — the app works without an API key.
# When set, the AI agent system will use this for LLM inference.
GOOGLE_API_KEY=your_google_api_key_here

# ── App Settings ──────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Front Line Whānau"
